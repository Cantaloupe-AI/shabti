# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Set to "true" to use Telegram only (no WhatsApp)
TELEGRAM_ONLY=

# Comma-separated additional bot tokens for agent swarm/teams
TELEGRAM_BOT_POOL=

# Claude Code OAuth token (from `claude-code auth`)
CLAUDE_CODE_OAUTH_TOKEN=

# Password for the web dashboard
DASHBOARD_PASSWORD=

# Display name for the assistant
ASSISTANT_NAME="Seshat"

# Timezone for scheduling
TZ=America/Denver

# Axiom logging (optional)
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=
AXIOM_QUERY_TOKEN=

# Linear integration (optional)
LINEAR_API_KEY=

# Context7 documentation lookup (optional)
CONTEXT_7_API_KEY=

# Dashboard API key for programmatic access (optional)
DASHBOARD_API_KEY=

# Vercel deployment (optional)
VERCEL_KEY=
VERCEL_PROJECT_ID=

# Slack integration (optional)
SLACK_USER_OAUTH_TOKEN=
SLACK_BOT_USER_OAUTH_TOKEN=
